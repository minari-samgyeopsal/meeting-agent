# Google Workspace
GWS_CRED_FILE=/path/to/credentials.json
# or
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/path/to/credentials.json
GWS_DOMAIN=parametacorp.com

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_ID=A0000000000
SLACK_APP_TOKEN=xapp-your-app-token

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Trello
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_TOKEN=your-trello-api-token
TRELLO_BOARD_ID=69731ce5

# Search / App
SEARCH_RESULTS_COUNT=5
LOG_LEVEL=INFO
CACHE_DIR=./cache
DRY_RUN=true
DRY_RUN_CALENDAR=true
DRY_RUN_TRELLO=true
TIMEZONE=Asia/Seoul
BRIEFING_HOUR=9
BRIEFING_MINUTE=0

# Drive paths
CONTACTS_FOLDER=Contacts
COMPANY_KNOWLEDGE_FILE=company_knowledge.md
MEETING_TRANSCRIPTS_FOLDER=MeetingTranscripts
MEETING_NOTES_FOLDER=MeetingNotes
GENERATED_DRAFTS_FOLDER=GeneratedDrafts
MEETING_STATE_FOLDER=MeetingState
MEETING_AUDIO_FOLDER=MeetingAudio

# Feature flags
ENABLE_AGENDA_AUTO_REGISTER=true
ENABLE_CONTACT_AUTO_SAVE=true
ENABLE_CALENDAR_AGENDA_SYNC=true
ENABLE_CHANNEL_MONITOR=true
ENABLE_CHANNEL_MONITOR_REALTIME=false
CHANNEL_MONITOR_MIN_TEXT_LENGTH=10
CHANNEL_MONITOR_BATCH_HOUR=17
CHANNEL_MONITOR_TARGET_CHANNELS=C01234567,C08999999
CHANNEL_MONITOR_REVIEW_DM_EMAIL=me@parametacorp.com
# or send directly to an existing DM / private channel id
CHANNEL_MONITOR_REVIEW_CHANNEL=

# ASR
